# 🧭 CASH COMPASS - Environment Template
# Copy this file to .env and fill in your actual credentials.
# DO NOT PUSH YOUR ACTUAL .env FILE!

PORT=5000
MONGO_URI=your_mongodb_connection_string

# BREVO (Email System)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxx
SENDER_EMAIL=your_verified_email@gmail.com
SENDER_NAME="Cash Compass"

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_secret_key
SESSION_SECRET=a_random_secure_string

# FRONTEND
FRONTEND_URL=http://localhost:5000
